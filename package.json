{
  "name": "prompt-profiler",
  "version": "0.1.0",
  "description": "Analyze local Claude Code / Cursor session data to surface a candidate's prompting-style signals.",
  "type": "module",
  "bin": {
    "prompt-profiler": "bin/prompt-profiler.js"
  },
  "files": [
    "bin",
    "lib",
    "public",
    "cli.js",
    "server.js",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/prompt-profiler.js serve",
    "serve": "node bin/prompt-profiler.js serve",
    "cli": "node bin/prompt-profiler.js",
    "report": "node bin/prompt-profiler.js report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "claude-code",
    "cursor",
    "codex",
    "opencode",
    "prompt",
    "prompting",
    "analysis",
    "cli",
    "developer-tools",
    "session-analysis",
    "hiring"
  ],
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5"
  }
}
